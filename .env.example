# Faculty Award Nomination System - Environment Template
# Copy to .env and fill in your values

# Required: Pinecone (vector database for CV embeddings)
PINECONE_API_KEY=your_pinecone_api_key

# Required: TAMU AI Chat API (LLM for ranking)
TAMU_API_KEY=your_tamu_api_key

# Optional: TAMU API base URL (default shown)
TAMU_API_BASE=https://chat-api.tamu.ai/api
